NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY: aún NO la usa ningún código (todo pasa por el service client).
# Necesaria hasta la Fase 2+ (PWA de cajero / cliente de navegador). Puede ir en blanco por ahora.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ⚠️ SECRETOS DE SERVIDOR — nunca los expongas al navegador (no llevan prefijo NEXT_PUBLIC_
# a propósito), nunca los commitees, y nunca los compartas fuera de .env.local / variables
# de entorno de Vercel. La service_role key da acceso TOTAL a la base de datos; las llaves
# de Apple firman los passes y los push de FM.
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_BASE_URL=

# Apple Wallet (Tarea 6 del plan: developer.apple.com → Pass Type ID + certificados + APNs key)
# Los _B64 son los archivos .pem/.p8 codificados con: base64 -w0 <archivo>
APPLE_TEAM_ID=
APPLE_PASS_TYPE_IDENTIFIER=
APPLE_SIGNER_CERT_B64=
APPLE_SIGNER_KEY_B64=
APPLE_WWDR_B64=
APNS_KEY_B64=
APNS_KEY_ID=
